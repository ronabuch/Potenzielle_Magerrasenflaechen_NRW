#Klassen zusammenfassen
classify_litho <- function(x) {
  
  # fehlende Werte
  if (is.na(x) || x == "") {
    return(NA_character_)
  }
  
  # 1. Wasser
  if (grepl("Gewässer", x, ignore.case = TRUE)) {
    return("Wasser")
  }
  
  # 2. Anthropogen
  if (grepl("Abraum|Müll|Bergematerial|Erdaushub",
            x, ignore.case = TRUE)) {
    return("Anthropogen")
  }
  
  # 3. Organisch
  if (grepl("Torf|Braunkohle|Steinkohle",
            x, ignore.case = TRUE)) {
    return("Organisch")
  }
  
  # 4. Kalkstein
  if (grepl("Kalkstein|Kalksandstein",
            x, ignore.case = TRUE)) {
    return("Kalkstein")
  }
  
  # 5. Dolomit
  if (grepl("Dolomit|Dolomitstein",
            x, ignore.case = TRUE)) {
    return("Dolomit")
  }
  
  # 6. Mergel
  if (grepl("Mergel|Mergelstein",
            x, ignore.case = TRUE)) {
    return("Mergel")
  }
  
  # 7. Evaporite
  if (grepl("Gips|Anhydrit|Steinsalz",
            x, ignore.case = TRUE)) {
    return("Evaporit")
  }
  
  # 8. Kristallin
  if (grepl("Vulkanit|Metamorphit|Quarzit|Roteisenstein",
            x, ignore.case = TRUE)) {
    return("Kristallin")
  }
  
  # 9. Feinklastisch
  if (grepl("Tonstein|Schluffstein|Ton|Schluff",
            x, ignore.case = TRUE) &&
      !grepl("Sand|Kies|Schotter",
             x, ignore.case = TRUE)) {
    return("Feinklastisch")
  }
  
  # 10. Grobklastisch
  if (grepl("Sand|Kies|Schotter|Feuersteinschotter",
            x, ignore.case = TRUE) &&
      !grepl("Ton|Schluff",
             x, ignore.case = TRUE)) {
    return("Grobklastisch")
  }
  
  # 11. Gemischt klastisch
  if (grepl("Sand|Kies|Schotter|Ton|Schluff",
            x, ignore.case = TRUE)) {
    return("Gemischt klastisch")
  }
  
  return("Sonstiges")
}

