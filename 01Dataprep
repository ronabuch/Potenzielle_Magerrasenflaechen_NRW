predictors <- rast("Daten/predictors/predictors.tif")

#Magerrasen-Flächen einladen
magerrasen_train <- st_read("Daten/training/magerrasen.gpkg")

#Projektion abfragen
st_crs(magerrasen_train)

#Attribute hinzufügen
magerrasen_train$PolyID <- 1:nrow(magerrasen_train)
magerrasen_train$magerrasen <- "ja_magerrasen"

#Zufallsstichprobe nehmen und mit Attributen verbinden
magerrasen_train <- sf::st_make_valid(magerrasen_train)
magerrasen_train <- sf::st_transform(magerrasen_train, 25832)

Zufallsstichprobe_magerrasen <- st_sample(magerrasen_train, size = 5000,
                                          type = "random")

#In sf-Objekt konvertieren
pts_sf2 <- st_as_sf(Zufallsstichprobe_magerrasen)

#Punkte mit Attributen der Polygone verknüpfen
Zufallsstichprobe_magerrasen <- st_join(pts_sf2, magerrasen_train)

#Werte aus Prädiktorenstack extrahieren und an Zufallsstichprobe anhängen

# Punkte in SpatVector umwandeln
Zufallsstichprobe_vect <- vect(Zufallsstichprobe_magerrasen)

#Nur die Spalte PolyID behalten, weil der Rest irrelevant ist
Zufallsstichprobe_vect_ID <- Zufallsstichprobe_vect[, c("PolyID", "magerrasen")]

# Rasterwerte extrahieren + Attribute der Punkte anhängen
Zufallsstichprobe_ID_predictors <- extract(predictors, Zufallsstichprobe_vect_ID, bind = TRUE)

#Wieder zu sf machen
#Data Frame + Geometrie der Punkte kombinieren
Zufallsstichprobe_ID_predictors_sf <- st_as_sf(Zufallsstichprobe_ID_predictors, geometry = st_geometry(Zufallsstichprobe_magerrasen))

#Speichern
st_write(Zufallsstichprobe_ID_predictors_sf,
         "Daten/training/Zufall_ffh_predictor_sf.gpkg",  delete_layer = TRUE)


