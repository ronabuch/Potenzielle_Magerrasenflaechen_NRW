library(terra)
library(sf)
library(blockCV)
library(ranger)
library(pROC)

setwd(".")

###########################
### Random Forest Model ###
###########################

#PrÃ¤diktoren einladen
predictors <- rast("Daten/predictors/predictors.tif")

#Zufallspunkte (aus FFH-Gebieten und peuso-absence) einladen
trainPoints_ffh <- st_read("Daten/training/Zufall_ffh_predictor_sf_new.gpkg")
trainPoints_absence <- st_read("Daten/training/Zufall_absence_predictor_5000_sf_new.gpkg")

#Zufallspunkte zu einem Datensatz kombinieren
trainData_sf <- rbind(trainPoints_ffh, trainPoints_absence)

#PrÃ¤diktornamen definieren
predictor_names <- names(predictors)

#Anpassungen vornehmen
trainData <- st_drop_geometry(trainData_sf) #Geometrie entfernen
trainData <- trainData[complete.cases(trainData[,predictor_names]),] #noData entfernen
trainData$magerrasen <- as.factor(trainData$magerrasen)
trainData_sf$magerrasen <- as.factor(trainData_sf$magerrasen)

###########################
##### Kreuzvalidierung ####
###########################

#### RÃ¤umlich blockierte Kreuzvalidierung ####
folds1000 <- cv_spatial(x = trainData_sf, column = "magerrasen", r = predictors,
  size = 1000, k = 5,  hexagon = TRUE)

# Klasse 1 = ja_magerrasen (positiv_event)
trainData_sf$magerrasen <- relevel(trainData_sf$magerrasen,
                                   ref = "nein_magerrasen")


#### AUC pro fold ####
auc_values <- numeric(length(folds1000$folds_list))

for (i in seq_along(folds1000$folds_list)) {
  
  train_idx <- folds1000$folds_list[[i]][[1]]
  test_idx  <- folds1000$folds_list[[i]][[2]]
  
  train <- trainData_sf[train_idx, ]
  test  <- trainData_sf[test_idx, ]
  
  rf <- ranger(
    magerrasen ~ . - PolyID,
    data = st_drop_geometry(train),
    probability = TRUE,
    num.trees = 500,
    importance = "permutation"
  )
  
  pred <- predict(rf, data = st_drop_geometry(test))
  
  prob <- pred$predictions[, "ja_magerrasen"]
  
  roc_obj <- roc(
    response = test$magerrasen,
    predictor = prob,
    levels = c("nein_magerrasen", "ja_magerrasen"),
    direction = "<"
  )
  
  auc_values[i] <- as.numeric(auc(roc_obj))
  
  cat("Fold", i, "AUC:", auc_values[i], "\n")
}

# Ergebnis der Kreuzvalidierung
mean_auc <- mean(auc_values)
sd_auc   <- sd(auc_values)

mean_auc #0.9861657
sd_auc #0.00199484

